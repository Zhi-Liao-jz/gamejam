[ext_resource type="Script" path="res://scenes/menu/panel_with_theme.gd" id="2_theme"]

[node name="DaySelect" type="Node"]
script = ExtResource("1_day")

[node name="CanvasLayer" type="CanvasLayer" parent="."]

[node name="RootPanel" type="PanelContainer" parent="CanvasLayer"]
anchors_preset = 8
