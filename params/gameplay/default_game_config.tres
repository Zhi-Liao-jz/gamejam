[sub_resource type="Resource" id="EconomyConfig_default"]
script = ExtResource("2_economy")

[sub_resource type="Resource" id="Equipment_shock_trap"]
script = ExtResource("10_equipment")
id = 1
key = &"shock_trap"
display_name = "电击陷阱"
price = 120
max_count = 3
refill_interval = 30.0
description = "安装到设备上，猴子操作时触发打断。"

[sub_resource type="Resource" id="Equipment_net"]
script = ExtResource("10_equipment")
id = 2
key = &"net"
display_name = "捕网"
price = 100
max_count = 3
refill_interval = 30.0
effect_duration = 10.0
description = "对当前房间猴子使用，使其 10 秒不能行动。"

[sub_resource type="Resource" id="EquipmentCatalog_default"]
script = ExtResource("9_catalog")
items = Array[ExtResource("10_equipment")]([SubResource("Equipment_shock_trap"), SubResource("Equipment_net")])

